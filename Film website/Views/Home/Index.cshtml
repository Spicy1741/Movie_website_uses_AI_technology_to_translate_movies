@{
    ViewData["Title"] = "CineHub Comic Edition";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/comic-styles.css" asp-append-version="true" />
}

<!-- Comic Book Floating Elements -->
<div class="comic-elements" id="comicElements">
    <!-- Dynamic comic elements will be added here -->
</div>

<!-- Hero Header -->
<header class="hero-header">
    <div class="header-container">
        <div class="logo-section">
            <div class="logo-circle">🎬</div>
            <h1>CINEHUB</h1>
            <p>COMIC EDITION</p>
        </div>
        <div class="header-content">
            <h2>EPIC MOVIE EXPERIENCE</h2>
            <p>Join the ultimate superhero streaming adventure!</p>
            <div class="header-buttons">
                <a href="@Url.Action("Login", "Account")" class="btn btn-primary">LOGIN HERO MODE</a>
                <a href="#featured" class="btn btn-secondary">EXPLORE MOVIES</a>
            </div>
        </div>
        <div class="hero-character">
            <div class="character-icon">🦸</div>
        </div>
    </div>
</header>

<!-- Navigation -->
<nav class="main-nav">
    <div class="nav-container">
        <div class="nav-logo">
            <span>🎬 CINEHUB</span>
        </div>
        <ul class="nav-menu">
            <li><a href="#home">HOME</a></li>
            <li><a href="#movies">MOVIES</a></li>
            <li><a href="#series">SERIES</a></li>
            <li><a href="#genres">GENRES</a></li>
            <li><a href="#contact">CONTACT</a></li>
        </ul>
        <div class="nav-auth">
            <a href="@Url.Action("Login", "Account")" class="login-btn">LOGIN</a>
        </div>
    </div>
</nav>

<!-- Featured Section -->
<section id="featured" class="featured-section">
    <div class="container">
        <h2>🌟 FEATURED EPIC MOVIES 🌟</h2>
        <div class="movies-grid">
            <div class="movie-card" onclick="openMovieDetails('epic-adventure')">
                <div class="movie-poster">
                    <div class="poster-placeholder">🎬 EPIC ADVENTURE</div>
                    <div class="movie-overlay">
                        <button class="play-btn">▶️ PLAY</button>
                    </div>
                </div>
                <div class="movie-info">
                    <h3>Epic Adventure</h3>
                    <p>Action • 2024 • ⭐ 9.5/10</p>
                </div>
            </div>

            <div class="movie-card" onclick="openMovieDetails('hero-legends')">
                <div class="movie-poster">
                    <div class="poster-placeholder">🦸 HERO LEGENDS</div>
                    <div class="movie-overlay">
                        <button class="play-btn">▶️ PLAY</button>
                    </div>
                </div>
                <div class="movie-info">
                    <h3>Hero Legends</h3>
                    <p>Superhero • 2024 • ⭐ 9.8/10</p>
                </div>
            </div>

            <div class="movie-card" onclick="openMovieDetails('cosmic-journey')">
                <div class="movie-poster">
                    <div class="poster-placeholder">🌌 COSMIC JOURNEY</div>
                    <div class="movie-overlay">
                        <button class="play-btn">▶️ PLAY</button>
                    </div>
                </div>
                <div class="movie-info">
                    <h3>Cosmic Journey</h3>
                    <p>Sci-Fi • 2024 • ⭐ 9.3/10</p>
                </div>
            </div>

            <div class="movie-card" onclick="openMovieDetails('legendary-quest')">
                <div class="movie-poster">
                    <div class="poster-placeholder">⚔️ LEGENDARY QUEST</div>
                    <div class="movie-overlay">
                        <button class="play-btn">▶️ PLAY</button>
                    </div>
                </div>
                <div class="movie-info">
                    <h3>Legendary Quest</h3>
                    <p>Fantasy • 2024 • ⭐ 9.6/10</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section">
    <div class="container">
        <h2>🎭 EPIC CATEGORIES 🎭</h2>
        <div class="categories-grid">
            <div class="category-card">
                <div class="category-icon">💥</div>
                <h3>ACTION</h3>
                <p>High-octane thrills and epic battles</p>
            </div>

            <div class="category-card">
                <div class="category-icon">🦸</div>
                <h3>SUPERHERO</h3>
                <p>Heroes saving the world in style</p>
            </div>

            <div class="category-card">
                <div class="category-icon">🌌</div>
                <h3>SCI-FI</h3>
                <p>Journey to distant galaxies</p>
            </div>

            <div class="category-card">
                <div class="category-icon">😂</div>
                <h3>COMEDY</h3>
                <p>Laugh until your sides hurt</p>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="main-footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-section">
                <h3>🎬 CINEHUB</h3>
                <p>The ultimate movie streaming experience with a comic book twist!</p>
            </div>
            <div class="footer-section">
                <h4>QUICK LINKS</h4>
                <ul>
                    <li><a href="#movies">Movies</a></li>
                    <li><a href="#series">Series</a></li>
                    <li><a href="#genres">Genres</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>FOLLOW US</h4>
                <div class="social-links">
                    <a href="#">📘 Facebook</a>
                    <a href="#">🐦 Twitter</a>
                    <a href="#">📸 Instagram</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 CineHub. All rights reserved. 🦸‍♂️</p>
        </div>
    </div>
</footer>

@section Scripts {
    <script src="~/js/comic-main.js" asp-append-version="true"></script>
    <script src="~/js/comic-details.js" asp-append-version="true"></script>
}